# Google Places API — для автоматической загрузки отзывов
# Инструкция: https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Place ID вашей клиники в Google Maps
# Найти: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=your_place_id_here
